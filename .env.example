# Azure Speech (Pronunciation Assessment).
# Leave both unset to run in mock mode: /api/assessment returns deterministic
# simulated results so the whole flow works without credentials.
AZURE_SPEECH_KEY=
AZURE_SPEECH_REGION=koreacentral

# Drill-audio TTS (npm run gen:hvpt) — both optional. Without them the
# script uses the Azure keys above, or falls back to free macOS `say` voices.
ELEVENLABS_API_KEY=
GOOGLE_TTS_API_KEY=

# Supabase (accounts + cross-device drill progress). Leave unset to keep
# progress in the browser's localStorage only — the app fully works without
# it. Setup: create a project at supabase.com, run supabase/schema.sql in the
# SQL editor, then paste Project Settings → API values here.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
